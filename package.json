{
  "name": "mail-viewer",
  "version": "1.2.7",
  "scripts": {
    "ng": "ng",
    "update": "ncu -u && npm i && cd server && ncu -u && npm i",
    "server": "node server/main.js &",
    "start": "ng serve",
    "prebuild": "eslint src --fix && npm run test:lint",
    "build": "ng build",
    "release": "npm version patch -m \"Upgrade to %s\"",
    "prerelease": "chmod a+x .scripts/pre-release.sh && bash .scripts/pre-release.sh",
    "postrelease": "chmod a+x .scripts/post-release.sh && bash .scripts/post-release.sh",
    "publish": "npm run build",
    "postpublish": "node .scripts/archive.js",
    "test": "ng test",
    "test:lint": "eslint src"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/platform-browser": "^21.2.16",
    "@angular/platform-browser-dynamic": "^21.2.16",
    "@angular/router": "^21.2.16",
    "archiver": "^8.0.0",
    "cors": "^2.8.6",
    "dompurify": "~3.4.8",
    "express": "^5.2.1",
    "postal-mime": "^2.7.4",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "^3.2.0",
    "@types/jasmine": "~6.0.0",
    "@types/jasminewd2": "^2.0.13",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "jasmine-core": "~6.2.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "ts-node": "~10.9.2",
    "typescript": "^5.9"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
